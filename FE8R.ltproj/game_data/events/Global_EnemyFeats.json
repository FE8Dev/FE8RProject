[
    {
        "name": "EnemyFeats",
        "trigger": "unit_select",
        "level_nid": null,
        "condition": "v('_ENEMYFEATS') == True",
        "commands": [],
        "only_once": false,
        "priority": 19,
        "_source": [
            "speak;;GLORY",
            "",
            "for;A;[unit.nid for unit in game.get_enemy_units()];",
            "    give_skill;{A};Feat_Enabler;no_banner",
            "    give_skill;{A};Feats_Disabler;no_banner",
            "",
            "level_var;FEATCOUNT;0",
            "level_var;FEATCOUNT;((DB.classes.get('{e:game.get_unit('{A}').klass}').tier)-1)*2",
            "",
            "",
            "   if;{e:game.get_unit('{A}').level} >= 5;",
            "        level_var;FEATCOUNT;v('FEATCOUNT')+1",
            "      if;{e:game.get_unit('{A}').level} >= 15;",
            "        level_var;FEATCOUNT;v('FEATCOUNT')+1",
            "      end",
            "   end",
            "",
            "   ",
            "#speak;;lvl {e:game.get_unit('{A}').level} feat {v:FEATCOUNT}  ",
            "",
            "",
            "",
            "    for;GIVEFEAT;range(1,{e:game.level_vars['FEATCOUNT']}+1)",
            "       if;{GIVEFEAT} == 1 or {GIVEFEAT} == 2",
            "        level_var;FEAT;game.get_random_choice([s.nid for s in DB.skills if s.components.get('copysafe') and s.nid not in [x.nid for x in unit.skills] and \"_T2\" not in s.nid and \"_T3\" not in s.nid]);",
            "        give_skill;{A};{v:FEAT};no_banner",
            "       end",
            "              if;{GIVEFEAT} == 3 or {GIVEFEAT} == 4",
            "        level_var;FEAT;game.get_random_choice([s.nid for s in DB.skills if s.components.get('copysafe') and s.nid not in [x.nid for x in unit.skills] and \"_T1\" not in s.nid and \"_T3\" not in s.nid]);",
            "        give_skill;{A};{v:FEAT};no_banner",
            "       end",
            "              if;{GIVEFEAT} == 5 or {GIVEFEAT} == 6",
            "        level_var;FEAT;game.get_random_choice([s.nid for s in DB.skills if s.components.get('copysafe') and s.nid not in [x.nid for x in unit.skills] and \"_T1\" not in s.nid and \"_T2\" not in s.nid]);",
            "        give_skill;{A};{v:FEAT};no_banner",
            "       end",
            "    endf",
            "endf",
            "",
            "",
            "",
            "#not has_skill(unit, 'MyUnit_T1_1st')",
            "",
            "# and not has_skills(unit, 'Feats_Disabler')",
            "#v('_ENEMYFEATS')",
            "#game.turncount == 1"
        ],
        "nid": "Global EnemyFeats"
    }
]